# Backup & extraction artifacts (миграция WP)
*.wpress
*.xml
extracted/

# Dependencies & build (Next.js)
node_modules/
site/node_modules/
site/.next/
site/out/

# Env
.env
.env*.local
site/.env
site/.env*.local
!.env.example

# Media: в git только WebP из site/public/uploads; оригиналы — extracted/ (локально)
site/public/uploads/**
!site/public/uploads/**/
!site/public/uploads/**/*.webp

# SEO pipeline — личные рабочие файлы
briefs/*
!briefs/.gitkeep
drafts/*
!drafts/.gitkeep
.claude/research
.claude/agent-memory

# GSC exports (генерируются scripts/gsc_export.py)
knowledge/gsc/*
!knowledge/gsc/.gitkeep

# Logs
logs
*.log
npm-debug.log*

# OS & IDE
.DS_Store
Thumbs.db
.idea/
.vscode/
