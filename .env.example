# Google Search Console — service account JSON (одна строка или путь к файлу)
GSC_SERVICE_ACCOUNT_JSON=

# Свойство сайта в GSC (URL-prefix или sc-domain:)
# Примеры: https://krashenayadoska.ru/  или  sc-domain:krashenayadoska.ru
GSC_SITE_URL=https://krashenayadoska.ru/

# Yandex Search API — Wordstat (AI Studio)
YANDEX_SEARCH_API_KEY=
# ID папки Yandex Cloud (опционально — определяется автоматически)
YANDEX_FOLDER_ID=
