42Z\" stroke=\"white\" stroke-miterlimit=\"10\"\u003e\u003c/path\u003e\u003cpath opacity=\"0.1\" d=\"M213.998 311.343C216.763 317.153 220.757 322.293 225.704 326.407C232.871 332.722 241.65 341.251 251.666 341.887C266.51 342.857 281.285 340.077 295.779 337.237C300.599 336.586 305.365 335.577 310.037 334.221C314.92 332.449 318.457 328.156 322.143 324.735C327.513 319.718 333.928 315.814 338.702 310.226C350.13 296.942 349.979 277.459 345.027 261.549C343.74 257.389 342.44 254.328 342.782 249.94C343.088 246.264 343.574 243.13 341.094 239.993C336.489 234.535 331.564 229.355 326.344 224.481C318.249 216.291 308.038 210.51 296.85 207.785C291.364 206.489 285.719 205.994 280.091 206.316C274.852 206.621 269.804 207.797 264.491 207.588C257.964 207.322 250.799 207.224 244.84 210.219C220.483 222.453 208.94 245.188 202.074 270.35C200.794 275.079 199.829 279.893 201.644 284.618C203.655 289.877 208.618 293.185 210.375 298.39C211.185 300.797 211.511 303.329 212.108 305.792C212.578 307.693 213.211 309.55 213.998 311.343Z\" stroke=\"white\" stroke-miterlimit=\"10\"\u003e\u003c/path\u003e\u003cpath opacity=\"0.1\" d=\"M229.89 301.544C231.942 305.866 234.91 309.689 238.587 312.749C243.911 317.454 250.42 323.749 257.896 324.27C268.921 324.993 279.916 322.924 290.684 320.809C294.271 320.337 297.817 319.586 301.288 318.565C304.978 317.237 307.587 314.036 310.297 311.513C314.292 307.78 319.055 304.874 322.61 300.727C331.101 290.809 331.036 276.337 327.333 264.521C326.177 261.786 325.613 258.837 325.681 255.868C325.922 253.121 326.275 250.8 324.424 248.48C321.011 244.425 317.355 240.581 313.477 236.969C307.451 230.884 299.857 226.589 291.538 224.56C287.456 223.602 283.259 223.233 279.073 223.465C275.223 223.986 271.349 224.311 267.467 224.437C262.621 224.226 257.289 224.139 252.859 226.385C234.738 235.487 226.156 252.389 221.056 271.114C219.794 274.516 219.681 278.237 220.734 281.71C222.241 285.632 225.907 288.085 227.229 291.957C227.877 293.812 228.072 295.617 228.511 297.458C228.857 298.856 229.318 300.222 229.89 301.544Z\" stroke=\"white\" stroke-miterlimit=\"10\"\u003e\u003c/path\u003e\u003cpath opacity=\"0.1\" d=\"M245.798 291.736C247.129 294.575 249.072 297.084 251.488 299.083C254.985 302.168 259.272 306.313 264.16 306.634C271.39 306.805 278.613 306.044 285.649 304.369C287.999 304.055 290.323 303.564 292.599 302.897C294.858 301.764 296.865 300.188 298.502 298.263C301.326 296.067 304.019 293.708 306.569 291.199C312.136 284.708 312.076 275.225 309.647 267.466C308.902 265.668 308.544 263.733 308.596 261.787C308.81 260.966 308.848 260.109 308.707 259.272C308.566 258.436 308.249 257.638 307.777 256.933C305.539 254.27 303.137 251.748 300.587 249.382C296.654 245.384 291.689 242.557 286.244 241.213C283.563 240.604 280.811 240.37 278.066 240.519C275.546 240.854 273.01 241.061 270.468 241.138C267.218 240.761 263.925 241.199 260.887 242.413C249.019 248.373 243.391 259.468 239.964 271.789C239.133 274.016 239.061 276.456 239.759 278.728C240.735 281.307 243.158 282.918 244.019 285.452C244.4 286.614 244.562 287.858 244.85 289.051C245.087 289.972 245.404 290.871 245.798 291.736Z\" stroke=\"white\" stroke-miterlimit=\"10\"\u003e\u003c/path\u003e\u003c/g\u003e\u003cdefs\u003e\u003cclipPath id=\"clip0_88_722\"\u003e\u003crect width=\"410\" height=\"394\" fill=\"white\" transform=\"translate(552.07 341.215) rotate(150)\"\u003e\u003c/rect\u003e\u003c/clipPath\u003e\u003c/defs\u003e\u003c/svg\u003e\t\t\t\n\t\t\t\t\t\u003ch3\u003eАндрей Сергеевич — технический директор / художник-исследователь\u003c/h3\u003e\t\t\t\t\n\t\t\u003ch6 data-spm-anchor-id=\"a2ty_o01.29997173.0.i90.3487c921NcamRz\"\u003eОн помогает создать широкую палитру оттенков. Обеспечивает нужные цветовые эффекты и качественное покрытие поверхности.\u003c/h6\u003e\u003ch6\u003eАндрей изучает влияние цвета на восприятие и эмоции. Его знания позволяют находить уникальные решения и вдохновлять заказчиков новыми идеями.\u003c/h6\u003e\t\t\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\u003cimg width=\"230\" height=\"300\" src=\"https://krashenayadoska.ru/wp-content/uploads/2025/04/frame-10-2-230x300.png\" alt=\"\" srcset=\"https://krashenayadoska.ru/wp-content/uploads/2025/04/frame-10-2-230x300.png 230w, https://krashenayadoska.ru/wp-content/uploads/2025/04/frame-10-2.png 460w\" sizes=\"(max-width: 230px) 100vw, 230px\" /\u003e\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\n\t\t\t\t\t\u003ch2\u003eСпециалисты по шлифовке дерева\u003c/h2\u003e\t\t\t\t\n\t\t\u003ch6 data-spm-anchor-id=\"a2ty_o01.29997173.0.i93.3487c921NcamRz\"\u003eШлифовка — важный этап обработки древесины. Она улучшает внешний вид и продлевает срок службы изделия.\u003c/h6\u003e\u003ch6 data-spm-anchor-id=\"a2ty_o01.29997173.0.i92.3487c921NcamRz\"\u003eНаши мастера владеют разными техниками. Они умеют работать с различными инструментами. Благодаря опыту, они превращают дерево в настоящее произведение искусства.\u003c/h6\u003e\t\t\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\u003cimg width=\"800\" height=\"928\" src=\"https://krashenayadoska.ru/wp-content/uploads/2025/06/photo_2025-06-23_18-02-45-883x1024.jpg\" alt=\"\" srcset=\"https://krashenayadoska.ru/wp-content/uploads/2025/06/photo_2025-06-23_18-02-45-883x1024.jpg 883w, https://krashenayadoska.ru/wp-content/uploads/2025/06/photo_2025-06-23_18-02-45-259x300.jpg 259w, https://krashenayadoska.ru/wp-content/uploads/2025/06/photo_2025-06-23_18-02-45-768x890.jpg 768w, https://krashenayadoska.ru/wp-content/uploads/2025/06/photo_2025-06-23_18-02-45.jpg 1104w\" sizes=\"(max-width: 800px) 100vw, 800px\" /\u003e\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\u003cimg width=\"768\" height=\"1024\" src=\"https://krashenayadoska.ru/wp-content/uploads/2025/04/5b9c1e92-ab35-4206-ad04-01c082afd167-768x1024.jpg\" alt=\"\" srcset=\"https://krashenayadoska.ru/wp-content/uploads/2025/04/5b9c1e92-ab35-4206-ad04-01c082afd167-768x1024.jpg 768w, https://krashenayadoska.ru/wp-content/uploads/2025/04/5b9c1e92-ab35-4206-ad04-01c082afd167-225x300.jpg 225w, https://krashenayadoska.ru/wp-content/uploads/2025/04/5b9c1e92-ab35-4206-ad04-01c082afd167.jpg 960w\" sizes=\"(max-width: 768px) 100vw, 768px\" /\u003e\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\u003cimg width=\"768\" height=\"1024\" src=\"https://krashenayadoska.ru/wp-content/uploads/2025/04/ae415409-13d9-4736-8e78-5ce92aa7c9b8-768x1024.jpg\" alt=\"\" srcset=\"https://krashenayadoska.ru/wp-content/uploads/2025/04/ae415409-13d9-4736-8e78-5ce92aa7c9b8-768x1024.jpg 768w, https://krashenayadoska.ru/wp-content/uploads/2025/04/ae415409-13d9-4736-8e78-5ce92aa7c9b8-225x300.jpg 225w, https://krashenayadoska.ru/wp-content/uploads/2025/04/ae415409-13d9-4736-8e78-5ce92aa7c9b8.jpg 960w\" sizes=\"(max-width: 768px) 100vw, 768px\" /\u003e\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\n\t\t\t\t\t\u003ch2\u003eСпециалисты по упаковке пиломатериалов\u003c/h2\u003e\t\t\t\t\n\t\t\u003ch6 data-spm-anchor-id=\"a2ty_o01.29997173.0.i95.3487c921NcamRz\"\u003eУпаковка играет ключевую роль при подготовке к отгрузке. Мы сохраняем целостность материалов во время транспортировки. Также обеспечиваем защиту от внешних воздействий.\u003c/h6\u003e\u003ch6 data-spm-anchor-id=\"a2ty_o01.29997173.0.i94.3487c921NcamRz\"\u003eБлагодаря их работе, наша продукция доходит до клиента в идеальном состоянии. Это повышает уровень сервиса и репутацию компании.\u003c/h6\u003e\t\t\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\u003cimg width=\"460\" height=\"600\" src=\"https://krashenayadoska.ru/wp-content/uploads/2025/04/frame-10-6.png\" alt=\"\" srcset=\"https://krashenayadoska.ru/wp-content/uploads/2025/04/frame-10-6.png 460w, https://krashenayadoska.ru/wp-content/uploads/2025/04/frame-10-6-230x300.png 230w\" sizes=\"(max-width: 460px) 100vw, 460px\" /\u003e\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\u003cimg width=\"800\" height=\"511\" src=\"https://krashenayadoska.ru/wp-content/uploads/2025/04/frame-53-3.png\" alt=\"\" srcset=\"https://krashenayadoska.ru/wp-content/uploads/2025/04/frame-53-3.png 940w, https://krashenayadoska.ru/wp-content/uploads/2025/04/frame-53-3-300x191.png 300w, https://krashenayadoska.ru/wp-content/uploads/2025/04/frame-53-3-768x490.png 768w\" sizes=\"(max-width: 800px) 100vw, 800px\" /\u003e\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\n\t\t\t\t\t\u003ch2\u003eСпециалисты  покрасочного станка\u003c/h2\u003e\t\t\t\t\n\t\t\u003ch6\u003eПокраска требует внимательности и точности. Наши операторы знают все технологии окраски древесины. Они профессионально подходят к своей работе. Эффективно выполняют задачи и обеспечивают высокое качество продукции.\u003c/h6\u003e\t\t\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\u003cimg width=\"768\" height=\"1024\" src=\"https://krashenayadoska.ru/wp-content/uploads/2025/04/8a349c47-7230-4089-be27-7f55e19973e0-768x1024.jpg\" alt=\"\" srcset=\"https://krashenayadoska.ru/wp-content/uploads/2025/04/8a349c47-7230-4089-be27-7f55e19973e0-768x1024.jpg 768w, https://krashenayadoska.ru/wp-content/uploads/2025/04/8a349c47-7230-4089-be27-7f55e19973e0-225x300.jpg 225w, https://krashenayadoska.ru/wp-content/uploads/2025/04/8a349c47-7230-4089-be27-7f55e19973e0.jpg 960w\" sizes=\"(max-width: 768px) 100vw, 768px\" /\u003e\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\u003cimg width=\"460\" height=\"600\" src=\"https://krashenayadoska.ru/wp-content/uploads/2025/04/frame-54-1.png\" alt=\"\" srcset=\"https://krashenayadoska.ru/wp-content/uploads/2025/04/frame-54-1.png 460w, https://krashenayadoska.ru/wp-content/uploads/2025/04/frame-54-1-230x300.png 230w\" sizes=\"(max-width: 460px) 100vw, 460px\" /\u003e\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\u003cimg width=\"768\" height=\"1024\" src=\"https://krashenayadoska.ru/wp-content/uploads/2025/04/77ca590f-46ed-4078-b05f-406492ad1565-768x1024.jpg\" alt=\"\" srcset=\"https://krashenayadoska.ru/wp-content/uploads/2025/04/77ca590f-46ed-4078-b05f-406492ad1565-768x1024.jpg 768w, https://krashenayadoska.ru/wp-content/uploads/2025/04/77ca590f-46ed-4078-b05f-406492ad1565-225x300.jpg 225w, https://krashenayadoska.ru/wp-content/uploads/2025/04/77ca590f-46ed-4078-b05f-406492ad1565.jpg 960w\" sizes=\"(max-width: 768px) 100vw, 768px\" /\u003e\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\n\t\t\t\t\t\u003ch2\u003eСпециалист по грунтовке пиломатериалов\u003c/h2\u003e\t\t\t\t\n\t\t\u003ch6 data-spm-anchor-id=\"a2ty_o01.29997173.0.i99.3487c921NcamRz\"\u003eГрунтование защищает древесину от влаги и вредителей. Мы используем составы, которые укрепляют структуру дерева и сохраняют его естественный вид.\u003c/h6\u003e\u003ch6 data-spm-anchor-id=\"a2ty_o01.29997173.0.i98.3487c921NcamRz\"\u003eПравильно подобранные средства увеличивают срок службы изделий. Это делает их более устойчивыми к внешним воздействиям.\u003c/h6\u003e\t\t\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\u003cimg width=\"688\" height=\"1024\" src=\"https://krashenayadoska.ru/wp-content/uploads/2025/04/e19affb5-211b-4db5-85de-8242c974e3c4-688x1024.jpg\" alt=\"\" srcset=\"https://krashenayadoska.ru/wp-content/uploads/2025/04/e19affb5-211b-4db5-85de-8242c974e3c4-688x1024.jpg 688w, https://krashenayadoska.ru/wp-content/uploads/2025/04/e19affb5-211b-4db5-85de-8242c974e3c4-202x300.jpg 202w, https://krashenayadoska.ru/wp-content/uploads/2025/04/e19affb5-211b-4db5-85de-8242c974e3c4-768x1143.jpg 768w, https://krashenayadoska.ru/wp-content/uploads/2025/04/e19affb5-211b-4db5-85de-8242c974e3c4.jpg 860w\" sizes=\"(max-width: 688px) 100vw, 688px\" /\u003e\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\n\t\t\u003ch4\u003eШирокий спектр услуг для сохранения красоты дерева:\u003c/h4\u003e\u003ch6\u003e\"Крашеная доска\" предлагает полный спектр услуг, направленных на преображение и защиту деревянных поверхностей. Независимо от того, нуждается ли фасад дома – в обновлении цвета, или вы хотите придать новый вид деревянному полу, мы готовы предложить оптимальное решение. Наш опыт и знания позволяют нам работать с различными породами дерева, используя современные технологии и высококачественные материалы.\u003c/h6\u003e\u003ch4\u003eПокраска:\u003c/h4\u003e\u003ch6\u003e Мы предлагаем широкий выбор красок и лаков от ведущих производителей, что позволяет подобрать оптимальное покрытие для каждого конкретного случая. Будь то акриловые, алкидные, масляные или водоэмульсионные краски, наши специалисты помогут выбрать цвет и текстуру, которые идеально впишутся в ваш интерьер или экстерьер.\u003c/h6\u003e\u003ch4\u003eРеставрация: \u003c/h4\u003e\u003ch6\u003eНаша команда  обладает глубокими знаниями и навыками по восстановлению деревянных изделий. Мы бережно удаляем старое покрытие, устраняем трещины и сколы, восстанавливаем утраченные элементы и воссоздаем оригинальный вид предмета.\u003c/h6\u003e\u003ch4\u003eШлифовка: \u003c/h4\u003e\u003ch6\u003eПрофессиональная шлифовка – это важный этап подготовки деревянной поверхности к покраске или лакировке. Мы используем современное оборудование, которое позволяет добиться идеально ровной и гладкой поверхности, что обеспечивает равномерное нанесение покрытия и долговечность результата.\u003c/h6\u003e\u003ch6\u003eОбработка антисептиками и антипиренами: Защита дерева от гниения, плесени, грибка и возгорания – это важная мера, которая позволяет продлить срок его службы. Мы используем современные антисептики и антипирены, которые эффективно защищают дерево от негативного воздействия окружающей среды.\u003c/h6\u003e\u003ch4\u003eПочему выбирают \"Крашеную доску\"?\u003c/h4\u003e\u003ch6\u003eВыбирая \"Крашеную доску\", вы получаете не просто покраску или реставрацию, а комплексный подход к преображению дерева. Мы гарантируем:\u003c/h6\u003e\u003ch6\u003eИндивидуальный подход: Мы внимательно выслушиваем пожелания каждого клиента и предлагаем решения, максимально соответствующие его потребностям и бюджету.\u003c/h6\u003e\u003ch6\u003eВысокое качество: Мы используем только проверенные материалы и технологии, что гарантирует долговечность и безупречный внешний вид обработанных поверхностей.\u003c/h6\u003e\u003ch6\u003eПрофессионализм: Наша команда состоит из опытных специалистов, которые любят свою работу и постоянно совершенствуют свои навыки.\u003c/h6\u003e\u003ch6\u003eСоблюдение сроков: Мы ценим время наших клиентов и всегда выполняем работы в оговоренные сроки.\u003c/h6\u003e\u003ch6\u003eГарантия на выполненные работы: Мы уверены в качестве наших услуг и предоставляем гарантию на все виды работ.\u003c/h6\u003e\u003ch6\u003e \u003c/h6\u003e\u003ch6\u003eООО \"Крашеная доска\" – это ваш надежный партнер в мире покраски и реставрации дерева. Мы готовы помочь вам преобразить ваш дом, сад или офис, придав деревянным поверхностям свежий и обновленный вид. Свяжитесь с нами сегодня, и мы с удовольствием проконсультируем вас и предложим оптимальное решение для вашего проекта. Позвольте нам вдохнуть новую жизнь в ваши любимые деревянные изделия и наслаждайтесь их красотой долгие годы.\u003c/h6\u003e\t\t\n\t\t\t\t\t\u003ca href=\"#top\"\u003e\n\t\t\t\t\u003csvg xmlns=\"http://www.w3.org/2000/svg\" width=\"17\" height=\"10\" viewBox=\"0 0 17 10\" fill=\"none\"\u003e\u003cpath d=\"M8.81795 3.6359L15.1821 10L17 8.18205L8.81795 -7.15298e-07L0.635896 8.18205L2.45384 10L8.81795 3.6359Z\" fill=\"white\"\u003e\u003c/path\u003e\u003c/svg\u003e\t\t\t\n\t\t\t\t\t\u003c/a\u003e\n\t\t\t\t\tНаверх",
    "link":  "https://krashenayadoska.ru/o-kompanii/",
