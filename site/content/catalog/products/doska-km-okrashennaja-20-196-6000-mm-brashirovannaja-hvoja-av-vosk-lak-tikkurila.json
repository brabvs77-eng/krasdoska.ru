    "content":  "\u003c!-- wp:gallery {\"linkTo\":\"none\"} --\u003e\n\u003cfigure class=\"wp-block-gallery has-nested-images columns-default is-cropped\"\u003e\u003c!-- wp:image {\"id\":3910,\"sizeSlug\":\"large\",\"linkDestination\":\"none\"} --\u003e\n\u003cfigure class=\"wp-block-image size-large\"\u003e\u003cimg src=\"https://krashenayadoska.ru/wp-content/uploads/2025/11/skandinavskaya_gladkaya_doska_uyv_krashennaya_21_146_6000mm_lessiruyushchaya_brashirovannaya_khvoya_-1024x1024.jpg\" alt=\"Планкен скошенный окрашенный лиственница АВ для фасада — KrashenayaDoska\" class=\"wp-image-3910\"/\u003e\u003c/figure\u003e\n\u003c!-- /wp:image --\u003e\n\n\u003c!-- wp:image {\"id\":3909,\"sizeSlug\":\"large\",\"linkDestination\":\"none\"} --\u003e\n\u003cfigure class=\"wp-block-image size-large\"\u003e\u003cimg src=\"https://krashenayadoska.ru/wp-content/uploads/2025/11/14.jpg\" alt=\"Скандинавская доска UYS окрашенная с поднятым ворсом для фасадов — KrashenayaDoska\" class=\"wp-image-3909\"/\u003e\u003c/figure\u003e\n\u003c!-- /wp:image --\u003e\n\n\u003c!-- wp:image {\"id\":3908,\"sizeSlug\":\"large\",\"linkDestination\":\"none\"} --\u003e\n\u003cfigure class=\"wp-block-image size-large\"\u003e\u003cimg src=\"https://krashenayadoska.ru/wp-content/uploads/2025/11/5641.jpg\" alt=\"\" class=\"wp-image-3908\"/\u003e\u003c/figure\u003e\n\u003c!-- /wp:image --\u003e\u003c/figure\u003e\n\u003c!-- /wp:gallery --\u003e\n\n\u003c!-- wp:heading {\"level\":3} --\u003e\n\u003ch3 class=\"wp-block-heading\"\u003e\u003cstrong\u003eДоска KM окрашенная 20×196×6000 мм — Брашированная хвоя АВ, воск + лак \u003c/strong\u003eSirca\u003c/h3\u003e\n\u003c!-- /wp:heading --\u003e\n\n\u003c!-- wp:paragraph --\u003e\n\u003cp\u003e\u003cstrong\u003eБренд:\u003c/strong\u003e KrashenayaDoska | \u003cstrong\u003eПроизводство:\u003c/strong\u003e Россия | \u003cstrong\u003eСрок поставки:\u003c/strong\u003e 14 дней | \u003cstrong\u003eДля внутренних работ\u003c/strong\u003e\u003c/p\u003e\n\u003c!-- /wp:paragraph --\u003e\n\n\u003c!-- wp:separator --\u003e\n\u003chr class=\"wp-block-separator has-alpha-channel-opacity\"/\u003e\n\u003c!-- /wp:separator --\u003e\n\n\u003c!-- wp:heading {\"level\":4} --\u003e\n\u003ch4 class=\"wp-block-heading\"\u003e✅ \u003cstrong\u003eПочему эта доска — не просто отделка, а арт-объект на стене?\u003c/strong\u003e\u003c/h4\u003e\n\u003c!-- /wp:heading --\u003e\n\n\u003c!-- wp:paragraph --\u003e\n\u003cp\u003e\u003cstrong\u003eБрашированная хвоя с тёплым оттенком и шелковистым покрытием воска Sirca\u003c/strong\u003e — это \u003cstrong\u003eне доска, а текстура характера\u003c/strong\u003e.\u003c/p\u003e\n\u003c!-- /wp:paragraph --\u003e\n\n\u003c!-- wp:paragraph --\u003e\n\u003cp\u003eВы не покупаете материал. Вы выбираете \u003cstrong\u003eстиль, который говорит без слов\u003c/strong\u003e:\u003cbr\u003e— Грубая, но утончённая\u003cbr\u003e— Естественная, но продуманная\u003cbr\u003e— Деревенская, но в стиле лофт-скандинав\u003c/p\u003e\n\u003c!-- /wp:paragraph --\u003e\n\n\u003c!-- wp:paragraph --\u003e\n\u003cp\u003eИдеально для:\u003c/p\u003e\n\u003c!-- /wp:paragraph --\u003e\n\n\u003c!-- wp:list --\u003e\n\u003cul class=\"wp-block-list\"\u003e\u003c!-- wp:list-item --\u003e\n\u003cli\u003eАкцентных стен в гостиной\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\n\n\u003c!-- wp:list-item --\u003e\n\u003cli\u003eПотолков в кабинете или спальне\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\n\n\u003c!-- wp:list-item --\u003e\n\u003cli\u003eДекоративных ниш, лестниц, наличников\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\n\n\u003c!-- wp:list-item --\u003e\n\u003cli\u003eБанных зон (в сухих помещениях)\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\n\n\u003c!-- wp:list-item --\u003e\n\u003cli\u003eИнтерьеров в стиле \u003cstrong\u003eJapandi, Scandi, Industrial, Rustic\u003c/strong\u003e\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\u003c/ul\u003e\n\u003c!-- /wp:list --\u003e\n\n\u003c!-- wp:quote --\u003e\n\u003cblockquote class=\"wp-block-quote\"\u003e\u003c!-- wp:paragraph --\u003e\n\u003cp\u003e💡 \u003cem\u003eБраширование — это не дефект. Это искусство. Мы не убираем древесину — мы открываем её душу.\u003c/em\u003e\u003c/p\u003e\n\u003c!-- /wp:paragraph --\u003e\u003c/blockquote\u003e\n\u003c!-- /wp:quote --\u003e\n\n\u003c!-- wp:separator --\u003e\n\u003chr class=\"wp-block-separator has-alpha-channel-opacity\"/\u003e\n\u003c!-- /wp:separator --\u003e\n\n\u003c!-- wp:heading {\"level\":4} --\u003e\n\u003ch4 class=\"wp-block-heading\"\u003e📏 \u003cstrong\u003eТехнические характеристики\u003c/strong\u003e\u003c/h4\u003e\n\u003c!-- /wp:heading --\u003e\n\n\u003c!-- wp:table --\u003e\n\u003cfigure class=\"wp-block-table\"\u003e\u003ctable class=\"has-fixed-layout\"\u003e\u003cthead\u003e\u003ctr\u003e\u003cth\u003eПараметр\u003c/th\u003e\u003cth\u003eЗначение\u003c/th\u003e\u003c/tr\u003e\u003c/thead\u003e\u003ctbody\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eТип\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003eДоска (профиль KM — прямые грани, без пазов)\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eПорода\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003eЕль / Сосна (северная, камерной сушки, сорт АВ — ровная структура, минимум сучков)\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eРазмеры\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003e20 × 196 × 6000 мм\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eРабочая ширина\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003e196 мм —\u003cstrong\u003eвся ширина используется\u003c/strong\u003e, без потерь\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eПлощадь одной доски\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003e1,18 м²\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eОбъём\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003e0,02352 м³\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eПоверхность\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003e\u003cstrong\u003eБрашированная\u003c/strong\u003e— ручная обработка полимерными щётками, выделяет годичные кольца\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eЦвет\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003eНатуральный оттенок хвои — тёплый, не агрессивный, с лёгкой фактурой\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eПокрытие\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003e\u003cstrong\u003eВоск + Лак \u003cstrong\u003eSirca\u003c/strong\u003e\u003c/strong\u003e— двойная защита: нежность воска + прочность лака\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eСтороны обработки\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003e3 стороны: грунт + воск + лак\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eКраска / грунт\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003e\u003cstrong\u003eSirca\u003c/strong\u003e— глубокая пропитка, без токсинов\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eПрименение\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003e\u003cstrong\u003eТолько внутренние работы\u003c/strong\u003e— стены, потолки, декор, доборы, откосы\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eГотово к монтажу\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003e✅ Не требует шлифовки, грунтовки или покраски на объекте\u003c/td\u003e\u003c/tr\u003e\u003c/tbody\u003e\u003c/table\u003e\u003c/figure\u003e\n\u003c!-- /wp:table --\u003e\n\n\u003c!-- wp:separator --\u003e\n\u003chr class=\"wp-block-separator has-alpha-channel-opacity\"/\u003e\n\u003c!-- /wp:separator --\u003e\n\n\u003c!-- wp:heading {\"level\":4} --\u003e\n\u003ch4 class=\"wp-block-heading\"\u003e🌲 \u003cstrong\u003eПочему брашированная хвоя — это роскошь в минимализме?\u003c/strong\u003e\u003c/h4\u003e\n\u003c!-- /wp:heading --\u003e\n\n\u003c!-- wp:paragraph --\u003e\n\u003cp\u003eБраширование — это \u003cstrong\u003eручная технология\u003c/strong\u003e, при которой мягкие волокна древесины аккуратно «выскабливаются» специальными полимерными щётками.\u003c/p\u003e\n\u003c!-- /wp:paragraph --\u003e\n\n\u003c!-- wp:paragraph --\u003e\n\u003cp\u003e👉 \u003cstrong\u003eРезультат:\u003c/strong\u003e\u003c/p\u003e\n\u003c!-- /wp:paragraph --\u003e\n\n\u003c!-- wp:list --\u003e\n\u003cul class=\"wp-block-list\"\u003e\u003c!-- wp:list-item --\u003e\n\u003cli\u003eГодичные кольца становятся \u003cstrong\u003eвыразительными рельефами\u003c/strong\u003e\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\n\n\u003c!-- wp:list-item --\u003e\n\u003cli\u003eПоверхность приобретает \u003cstrong\u003eвоздушную, почти каменную текстуру\u003c/strong\u003e\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\n\n\u003c!-- wp:list-item --\u003e\n\u003cli\u003eДревесина \u003cstrong\u003eне кажется «дешёвой»\u003c/strong\u003e — она выглядит как ручная работа старого плотника\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\n\n\u003c!-- wp:list-item --\u003e\n\u003cli\u003e\u003cstrong\u003eСрок службы покрытия возрастает в 2–3 раза\u003c/strong\u003e по сравнению со строганной поверхностью\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\u003c/ul\u003e\n\u003c!-- /wp:list --\u003e\n\n\u003c!-- wp:quote --\u003e\n\u003cblockquote class=\"wp-block-quote\"\u003e\u003c!-- wp:paragraph --\u003e\n\u003cp\u003e⚠️ \u003cstrong\u003eВажно:\u003c/strong\u003e Брашированная доска — это \u003cstrong\u003eакцент\u003c/strong\u003e, а не фон. Используйте её на одной стене, потолке или как рамку для зоны отдыха — чтобы не перегружать интерьер.\u003c/p\u003e\n\u003c!-- /wp:paragraph --\u003e\u003c/blockquote\u003e\n\u003c!-- /wp:quote --\u003e\n\n\u003c!-- wp:separator --\u003e\n\u003chr class=\"wp-block-separator has-alpha-channel-opacity\"/\u003e\n\u003c!-- /wp:separator --\u003e\n\n\u003c!-- wp:heading {\"level\":4} --\u003e\n\u003ch4 class=\"wp-block-heading\"\u003e🎨 \u003cstrong\u003eПокрытие: Воск + Лак \u003cstrong\u003eSirca\u003c/strong\u003e — Как в скандинавских домах\u003c/strong\u003e\u003c/h4\u003e\n\u003c!-- /wp:heading --\u003e\n\n\u003c!-- wp:paragraph --\u003e\n\u003cp\u003eМы не «покрываем» — мы \u003cstrong\u003eоблагораживаем\u003c/strong\u003e.\u003c/p\u003e\n\u003c!-- /wp:paragraph --\u003e\n\n\u003c!-- wp:table --\u003e\n\u003cfigure class=\"wp-block-table\"\u003e\u003ctable class=\"has-fixed-layout\"\u003e\u003cthead\u003e\u003ctr\u003e\u003cth\u003eЭлемент\u003c/th\u003e\u003cth\u003eПреимущество\u003c/th\u003e\u003c/tr\u003e\u003c/thead\u003e\u003ctbody\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eВоск \u003cstrong\u003e\u003cstrong\u003eSirca\u003c/strong\u003e\u003c/strong\u003e\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003eПроникает в древесину, создаёт \u003cstrong\u003eшелковистое, тёплое ощущение\u003c/strong\u003e на ощупь. Отталкивает влагу и пыль. Идеален для стен и потолков в спальнях, кабинетах, банях (в сухих зонах).\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eЛак \u003cstrong\u003e\u003cstrong\u003eSirca\u003c/strong\u003e\u003c/strong\u003e (полуматовый)\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003eФормирует \u003cstrong\u003eпрозрачную, износостойкую плёнку\u003c/strong\u003e— защищает от УФ, плесени, царапин. Не желтеет, не трескается.\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eСочетание\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003eВоск —\u003cstrong\u003eтеплота и тактильность\u003c/strong\u003e, лак —\u003cstrong\u003eзащита и долговечность\u003c/strong\u003e. Результат: \u003cstrong\u003eинтерьер, который хочется трогать и возвращаться в него.\u003c/strong\u003e\u003c/td\u003e\u003c/tr\u003e\u003c/tbody\u003e\u003c/table\u003e\u003c/figure\u003e\n\u003c!-- /wp:table --\u003e\n\n\u003c!-- wp:quote --\u003e\n\u003cblockquote class=\"wp-block-quote\"\u003e\u003c!-- wp:paragraph --\u003e\n\u003cp\u003e✅ Без запаха после высыхания — безопасно для детей, аллергиков, животных\u003cbr\u003e✅ Не применяется для полов — только для вертикальных поверхностей\u003c/p\u003e\n\u003c!-- /wp:paragraph --\u003e\u003c/blockquote\u003e\n\u003c!-- /wp:quote --\u003e\n\n\u003c!-- wp:separator --\u003e\n\u003chr class=\"wp-block-separator has-alpha-channel-opacity\"/\u003e\n\u003c!-- /wp:separator --\u003e\n\n\u003c!-- wp:heading {\"level\":4} --\u003e\n\u003ch4 class=\"wp-block-heading\"\u003e🏡 \u003cstrong\u003eГде использовать?\u003c/strong\u003e\u003c/h4\u003e\n\u003c!-- /wp:heading --\u003e\n\n\u003c!-- wp:paragraph --\u003e\n\u003cp\u003eИдеально для:\u003c/p\u003e\n\u003c!-- /wp:paragraph --\u003e\n\n\u003c!-- wp:list --\u003e\n\u003cul class=\"wp-block-list\"\u003e\u003c!-- wp:list-item --\u003e\n\u003cli\u003e\u003cstrong\u003eАкцентной стены\u003c/strong\u003e в гостиной — эффект «натурального камня» из дерева\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\n\n\u003c!-- wp:list-item --\u003e\n\u003cli\u003e\u003cstrong\u003eПотолков\u003c/strong\u003e — создаёт ощущение объёма и уюта\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\n\n\u003c!-- wp:list-item --\u003e\n\u003cli\u003e\u003cstrong\u003eНаличников, откосов, доборов\u003c/strong\u003e — превращает простые элементы в детали дизайна\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\n\n\u003c!-- wp:list-item --\u003e\n\u003cli\u003e\u003cstrong\u003eЛестниц, перил, угловых зон\u003c/strong\u003e — добавляет глубины и характера\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\n\n\u003c!-- wp:list-item --\u003e\n\u003cli\u003e\u003cstrong\u003eБанных предбанников, зон отдыха\u003c/strong\u003e — если не контактирует с паром\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\u003c/ul\u003e\n\u003c!-- /wp:list --\u003e\n\n\u003c!-- wp:quote --\u003e\n\u003cblockquote class=\"wp-block-quote\"\u003e\u003c!-- wp:paragraph --\u003e\n\u003cp\u003e💡 \u003cstrong\u003eСовет дизайнера:\u003c/strong\u003e\u003cbr\u003e\u003cem\u003eКомбинируйте брашированную дос