    "content":  "\u003c!-- wp:gallery {\"linkTo\":\"none\"} --\u003e\n\u003cfigure class=\"wp-block-gallery has-nested-images columns-default is-cropped\"\u003e\u003c!-- wp:image {\"id\":3910,\"sizeSlug\":\"large\",\"linkDestination\":\"none\"} --\u003e\n\u003cfigure class=\"wp-block-image size-large\"\u003e\u003cimg src=\"https://krashenayadoska.ru/wp-content/uploads/2025/11/skandinavskaya_gladkaya_doska_uyv_krashennaya_21_146_6000mm_lessiruyushchaya_brashirovannaya_khvoya_-1024x1024.jpg\" alt=\"Планкен скошенный окрашенный лиственница АВ для фасада — KrashenayaDoska\" class=\"wp-image-3910\"/\u003e\u003c/figure\u003e\n\u003c!-- /wp:image --\u003e\n\n\u003c!-- wp:image {\"id\":3909,\"sizeSlug\":\"large\",\"linkDestination\":\"none\"} --\u003e\n\u003cfigure class=\"wp-block-image size-large\"\u003e\u003cimg src=\"https://krashenayadoska.ru/wp-content/uploads/2025/11/14.jpg\" alt=\"Скандинавская доска UYS окрашенная с поднятым ворсом для фасадов — KrashenayaDoska\" class=\"wp-image-3909\"/\u003e\u003c/figure\u003e\n\u003c!-- /wp:image --\u003e\n\n\u003c!-- wp:image {\"id\":3908,\"sizeSlug\":\"large\",\"linkDestination\":\"none\"} --\u003e\n\u003cfigure class=\"wp-block-image size-large\"\u003e\u003cimg src=\"https://krashenayadoska.ru/wp-content/uploads/2025/11/5641.jpg\" alt=\"\" class=\"wp-image-3908\"/\u003e\u003c/figure\u003e\n\u003c!-- /wp:image --\u003e\u003c/figure\u003e\n\u003c!-- /wp:gallery --\u003e\n\n\u003c!-- wp:heading {\"level\":3} --\u003e\n\u003ch3 class=\"wp-block-heading\"\u003e\u003cstrong\u003eИмитация бруса UTVF окрашенная 23×196×6000 мм — Шлифованная ель АВ, воск + лак, темно-бордовый\u003c/strong\u003e\u003c/h3\u003e\n\u003c!-- /wp:heading --\u003e\n\n\u003c!-- wp:paragraph --\u003e\n\u003cp\u003e\u003cstrong\u003eБренд:\u003c/strong\u003e KrashenayaDoska | \u003cstrong\u003eПроизводство:\u003c/strong\u003e Россия | \u003cstrong\u003eСрок поставки:\u003c/strong\u003e 14 дней | \u003cstrong\u003eДля внутренних работ\u003c/strong\u003e\u003c/p\u003e\n\u003c!-- /wp:paragraph --\u003e\n\n\u003c!-- wp:separator --\u003e\n\u003chr class=\"wp-block-separator has-alpha-channel-opacity\"/\u003e\n\u003c!-- /wp:separator --\u003e\n\n\u003c!-- wp:heading {\"level\":4} --\u003e\n\u003ch4 class=\"wp-block-heading\"\u003e✅ \u003cstrong\u003eПочему эта имитация бруса — не просто доска, а интерьер в стиле Scandi-Luxe?\u003c/strong\u003e\u003c/h4\u003e\n\u003c!-- /wp:heading --\u003e\n\n\u003c!-- wp:paragraph --\u003e\n\u003cp\u003e\u003cstrong\u003eТемно-бордовый цвет, глубокая шлифовка, натуральный воск и лак Sirca\u003c/strong\u003e — всё это создаёт эффект \u003cstrong\u003eдорогой, цельной древесины\u003c/strong\u003e, будто стены и потолок вырезаны из одного массива.\u003c/p\u003e\n\u003c!-- /wp:paragraph --\u003e\n\n\u003c!-- wp:paragraph --\u003e\n\u003cp\u003eЭто \u003cstrong\u003eне пластик, не ДВП, не ЛДСП\u003c/strong\u003e — это \u003cstrong\u003eнастоящая ель северного происхождения\u003c/strong\u003e, обработанная как мебель для коттеджа в Швеции.\u003c/p\u003e\n\u003c!-- /wp:paragraph --\u003e\n\n\u003c!-- wp:paragraph --\u003e\n\u003cp\u003eИдеально для:\u003c/p\u003e\n\u003c!-- /wp:paragraph --\u003e\n\n\u003c!-- wp:list --\u003e\n\u003cul class=\"wp-block-list\"\u003e\u003c!-- wp:list-item --\u003e\n\u003cli\u003eИнтерьеров загородных домов\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\n\n\u003c!-- wp:list-item --\u003e\n\u003cli\u003eБань и саун (в сухих зонах)\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\n\n\u003c!-- wp:list-item --\u003e\n\u003cli\u003eГостиных, спален, кабинетов\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\n\n\u003c!-- wp:list-item --\u003e\n\u003cli\u003eПотолков и стен в стиле минимализм, лофт, скандинавский шик\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\u003c/ul\u003e\n\u003c!-- /wp:list --\u003e\n\n\u003c!-- wp:separator --\u003e\n\u003chr class=\"wp-block-separator has-alpha-channel-opacity\"/\u003e\n\u003c!-- /wp:separator --\u003e\n\n\u003c!-- wp:heading {\"level\":4} --\u003e\n\u003ch4 class=\"wp-block-heading\"\u003e📏 \u003cstrong\u003eТехнические характеристики\u003c/strong\u003e\u003c/h4\u003e\n\u003c!-- /wp:heading --\u003e\n\n\u003c!-- wp:table --\u003e\n\u003cfigure class=\"wp-block-table\"\u003e\u003ctable class=\"has-fixed-layout\"\u003e\u003cthead\u003e\u003ctr\u003e\u003cth\u003eПараметр\u003c/th\u003e\u003cth\u003eЗначение\u003c/th\u003e\u003c/tr\u003e\u003c/thead\u003e\u003ctbody\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eТип\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003eИмитация бруса (профиль UTVF — усечённая трапеция с удлинённым шипом 20 мм)\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eПорода\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003eЕль (северная, камерной сушки, сорт АВ — минимальные сучки, ровная текстура)\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eРазмеры\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003e23 × 196 × 6000 мм\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eРабочая ширина\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003e180 мм (за счёт шипа)\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eПлощадь одной доски\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003e1,18 м²\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eРабочая площадь\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003e1,08 м²\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eОбъём\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003e0,02705 м³\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eПоверхность\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003e\u003cstrong\u003eГлубокая шлифовка\u003c/strong\u003e— 100% гладкость, без заноз, раскрытые поры\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eЦвет\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003e\u003cstrong\u003eТемно-бордовый\u003c/strong\u003e— глубокий, насыщенный, с тёплым отливом\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eПокрытие\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003e\u003cstrong\u003eВоск + Лак \u003cstrong\u003eSirca\u003c/strong\u003e\u003c/strong\u003e— двойная защита и эстетика\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eСтороны обработки\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003e3 стороны: грунт + воск + лак\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eКраска / покрытие\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003e\u003cstrong\u003eTalatu\u003c/strong\u003e(грунт),\u003cstrong\u003e\u003cstrong\u003eSirca\u003c/strong\u003e\u003c/strong\u003e(воск и лак) — экологичные, без токсинов\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eПрименение\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003e\u003cstrong\u003eТолько внутренние работы\u003c/strong\u003e— стены, потолки, бани (в сухих зонах), кабинеты\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eГотово к монтажу\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003e✅ Не требует шлифовки, грунтовки или покраски на объекте\u003c/td\u003e\u003c/tr\u003e\u003c/tbody\u003e\u003c/table\u003e\u003c/figure\u003e\n\u003c!-- /wp:table --\u003e\n\n\u003c!-- wp:separator --\u003e\n\u003chr class=\"wp-block-separator has-alpha-channel-opacity\"/\u003e\n\u003c!-- /wp:separator --\u003e\n\n\u003c!-- wp:heading {\"level\":4} --\u003e\n\u003ch4 class=\"wp-block-heading\"\u003e🌲 \u003cstrong\u003eПочему именно ель АВ?\u003c/strong\u003e\u003c/h4\u003e\n\u003c!-- /wp:heading --\u003e\n\n\u003c!-- wp:paragraph --\u003e\n\u003cp\u003eЕль — \u003cstrong\u003eмягкая, светлая, с тонкой текстурой\u003c/strong\u003e — идеальный холст для глубоких цветов.\u003c/p\u003e\n\u003c!-- /wp:paragraph --\u003e\n\n\u003c!-- wp:list --\u003e\n\u003cul class=\"wp-block-list\"\u003e\u003c!-- wp:list-item --\u003e\n\u003cli\u003e\u003cstrong\u003eСорт АВ\u003c/strong\u003e — только без сучков С и ниже, ровная поверхность, без трещин.\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\n\n\u003c!-- wp:list-item --\u003e\n\u003cli\u003e\u003cstrong\u003eCушка\u003c/strong\u003e — древесина не коробится, не трескается после монтажа.\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\n\n\u003c!-- wp:list-item --\u003e\n\u003cli\u003e\u003cstrong\u003eШлифовка\u003c/strong\u003e — не просто «зачистка», а \u003cstrong\u003eтехнология, раскрывающая поры\u003c/strong\u003e.\u003cbr\u003e→ Краска впитывается глубже\u003cbr\u003e→ Цвет становится \u003cstrong\u003eнасыщеннее в 2 раза\u003c/strong\u003e\u003cbr\u003e→ Покрытие служит \u003cstrong\u003eв 3 раза дольше\u003c/strong\u003e\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\u003c/ul\u003e\n\u003c!-- /wp:list --\u003e\n\n\u003c!-- wp:quote --\u003e\n\u003cblockquote class=\"wp-block-quote\"\u003e\u003c!-- wp:paragraph --\u003e\n\u003cp\u003e💡 \u003cem\u003eШлифованная поверхность — это как шелк, а не шершавая доска. Касаться — удовольствие.\u003c/em\u003e\u003c/p\u003e\n\u003c!-- /wp:paragraph --\u003e\u003c/blockquote\u003e\n\u003c!-- /wp:quote --\u003e\n\n\u003c!-- wp:separator --\u003e\n\u003chr class=\"wp-block-separator has-alpha-channel-opacity\"/\u003e\n\u003c!-- /wp:separator --\u003e\n\n\u003c!-- wp:heading {\"level\":4} --\u003e\n\u003ch4 class=\"wp-block-heading\"\u003e🎨 \u003cstrong\u003eПокрытие: Воск + Лак \u003cstrong\u003eSirca\u003c/strong\u003e — Двойная защита, как в скандинавских домах\u003c/strong\u003e\u003c/h4\u003e\n\u003c!-- /wp:heading --\u003e\n\n\u003c!-- wp:paragraph --\u003e\n\u003cp\u003eМы не используем обычный лак. Мы применяем \u003cstrong\u003eдвуслойную систему\u003c/strong\u003e — \u003cstrong\u003eнатуральный воск + водоразбавляемый лак \u003cstrong\u003eSirca\u003c/strong\u003e\u003c/strong\u003e — по технологии, как для мебели высокого класса.\u003c/p\u003e\n\u003c!-- /wp:paragraph --\u003e\n\n\u003c!-- wp:table --\u003e\n\u003cfigure class=\"wp-block-table\"\u003e\u003ctable class=\"has-fixed-layout\"\u003e\u003cthead\u003e\u003ctr\u003e\u003cth\u003eЭлемент\u003c/th\u003e\u003cth\u003eПреимущество\u003c/th\u003e\u003c/tr\u003e\u003c/thead\u003e\u003ctbody\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eВоск \u003cstrong\u003eSirca\u003c/strong\u003e\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003eПроникает в древесину, создаёт \u003cstrong\u003eшелковистое, тёплое покрытие\u003c/strong\u003e, отталкивает влагу и грязь. Идеален для стен и потолков в банях и спальнях.\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eЛак \u003cstrong\u003eSirca\u003c/strong\u003e (полуматовый)\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003eФормирует \u003cstrong\u003eпрозрачную, износостойкую плёнку\u003c/strong\u003e, защищает от УФ, плесени, пыли. Не желтеет, не трескается.\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003ctd\u003e\u003cstrong\u003eСочетание\u003c/strong\u003e\u003c/td\u003e\u003ctd\u003eВоск —\u003cstrong\u003eтеплота и тактильность\u003c/strong\u003e, лак —\u003cstrong\u003eдолговечность и блеск\u003c/strong\u003e. Результат: \u003cstrong\u003eинтерьер, который дышит и выглядит дорого.\u003c/strong\u003e\u003c/td\u003e\u003c/tr\u003e\u003c/tbody\u003e\u003c/table\u003e\u003c/figure\u003e\n\u003c!-- /wp:table --\u003e\n\n\u003c!-- wp:quote --\u003e\n\u003cblockquote class=\"wp-block-quote\"\u003e\u003c!-- wp:paragraph --\u003e\n\u003cp\u003e✅ Без запаха после высыхания — безопасно для детей, аллергиков, животных.\u003cbr\u003e✅ Не применяется для полов — только для стен и потолков.\u003c/p\u003e\n\u003c!-- /wp:paragraph --\u003e\u003c/blockquote\u003e\n\u003c!-- /wp:quote --\u003e\n\n\u003c!-- wp:separator --\u003e\n\u003chr class=\"wp-block-separator has-alpha-channel-opacity\"/\u003e\n\u003c!-- /wp:separator --\u003e\n\n\u003c!-- wp:heading {\"level\":4} --\u003e\n\u003ch4 class=\"wp-block-heading\"\u003e🏡 \u003cstrong\u003eГде использовать?\u003c/strong\u003e\u003c/h4\u003e\n\u003c!-- /wp:heading --\u003e\n\n\u003c!-- wp:paragraph --\u003e\n\u003cp\u003eИдеально для:\u003c/p\u003e\n\u003c!-- /wp:paragraph --\u003e\n\n\u003c!-- wp:list --\u003e\n\u003cul class=\"wp-block-list\"\u003e\u003c!-- wp:list-item --\u003e\n\u003cli\u003e\u003cstrong\u003eСтен гостиных и спален\u003c/strong\u003e — создают атмосферу уюта и роскоши\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\n\n\u003c!-- wp:list-item --\u003e\n\u003cli\u003e\u003cstrong\u003eПотолков\u003c/strong\u003e — визуально «поднимают» высоту, добавляют глубину\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\n\n\u003c!-- wp:list-item --\u003e\n\u003cli\u003e\u003cstrong\u003eБань и саун (в парной — не использовать!)\u003c/strong\u003e — в предбанниках, зонах отдыха\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\n\n\u003c!-- wp:list-item --\u003e\n\u003cli\u003e\u003cstrong\u003eКабинетов, библиотек, детских\u003c/strong\u003e — тёплый, натуральный, не агрессивный цвет\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\n\n\u003c!-- wp:list-item --\u003e\n\u003cli\u003e\u003cstrong\u003eДизайнерских интерьеров\u003c/strong\u003e — сочетается с бетоном, металлом, текстилем в стиле Scandi, Japandi, Loft\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\u003c/ul\u003e\n\u003c!-- /wp:list --\u003e\n\n\u003c!-- wp:quote --\u003e\n\u003cblockquote class=\"wp-block-quote\"\u003e\u003c!-- wp:paragraph --\u003e\n\u003cp\u003e💡 \u003cstrong\u003eСовет дизайнеров:\u003c/strong\u003e Комбинируйте с \u003cstrong\u003e\u003ca href=\"https://krashenayadoska.ru/krashenaja-vagonka-shtil-iz-angarskoj-sosny-brashirovannaja-okrashennaja-sort-avs-115-14-4000-mm/\"\u003eвагонкой\u003c/a\u003e, \u003ca href=\"https://krashenayadoska.ru/skandinavskaya-doska-uys-okrashennaya-podnyatyj-vors/\"\u003eдоской UYS\u003c/a\u003e или массивом\u003c/strong\u003e — создавайте эффект «постепенного перехода» от грубого к изысканному.\u003c/p\u003e\n\u003c!-- /wp:paragraph --\u003e\u003c/blockquote\u003e\n\u003c!-- /wp:quote --\u003e\n\n\u003c!-- wp:separator --\u003e\n\u003chr class=\"wp-block-separator has-alpha-channel-opacity\"/\u003e\n\u003c!-- /wp:separator --\u003e\n\n\u003c!-- wp:heading {\"level\":4} --\u003e\n\u003ch4 class=\"wp-block-heading\"\u003e🛠️ \u003cstrong\u003eКак мы делаем? Европейская технология, российское качество\u003c/strong\u003e\u003c/h4\u003e\n\u003c!-- /wp:heading --\u003e\n\n\u003c!-- wp:list --\u003e\n\u003cul class=\"wp-block-list\"\u003e\u003c!-- wp:list-item --\u003e\n\u003cli\u003e\u003cstrong\u003eОборудование:\u003c/strong\u003e AEG , БелАбразив\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\n\n\u003c!-- wp:list-item --\u003e\n\u003cli\u003e\u003cstrong\u003eКонтроль:\u003c/strong\u003e\u003c!-- wp:list --\u003e\n\u003cul class=\"wp-block-list\"\u003e\u003c!-- wp:list-item --\u003e\n\u003cli\u003eШлифовка — до 180–220 grit (как у мебели)\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\n\n\u003c!-- wp:list-item --\u003e\n\u003cli\u003eГрунтовка — 3 стороны, глубокое проникновение\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\n\n\u003c!-- wp:list-item --\u003e\n\u003cli\u003eНанесение воска и лака — в условиях чистого цеха, без пыли\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\u003c/ul\u003e\n\u003c!-- /wp:list --\u003e\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\n\n\u003c!-- wp:list-item --\u003e\n\u003cli\u003e\u003cstrong\u003eСушка\u003c/strong\u003e \u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\n\n\u003c!-- wp:list-item --\u003e\n\u003cli\u003e\u003cstrong\u003eКаждая доска\u003c/strong\u003e — визуальный контроль перед упаковкой\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\u003c/ul\u003e\n\u003c!-- /wp:list --\u003e\n\n\u003c!-- wp:quote --\u003e\n\u003cblockquote class=\"wp-block-quote\"\u003e\u003c!-- wp:paragraph --\u003e\n\u003cp\u003e✅ \u003cstrong\u003eГотово к монтажу.\u003c/strong\u003e Никакой пыли, никакой покраски, никаких запахов — просто вешайте и наслаждайтесь.\u003c/p\u003e\n\u003c!-- /wp:paragraph --\u003e\u003c/blockquote\u003e\n\u003c!-- /wp:quote --\u003e\n\n\u003c!-- wp:separator --\u003e\n\u003chr class=\"wp-block-separator has-alpha-channel-opacity\"/\u003e\n\u003c!-- /wp:separator --\u003e\n\n\u003c!-- wp:heading {\"level\":4} --\u003e\n\u003ch4 class=\"wp-block-heading\"\u003e📦 \u003cstrong\u003eДоставка и заказ\u003c/strong\u003e\u003c/h4\u003e\n\u003c!-- /wp:heading --\u003e\n\n\u003c!-- wp:list --\u003e\n\u003cul class=\"wp-block-list\"\u003e\u003c!-- wp:list-item --\u003e\n\u003cli\u003e\u003cstrong\u003eСамовывоз:\u003c/strong\u003e Московская область, г. Истра, промзона — заберите в тот же день\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\n\n\u003c!-- wp:list-item --\u003e\n\u003cli\u003e\u003cstrong\u003eДоставка по России:\u003c/strong\u003e транспортными компаниями — до терминала или на объект (с разгрузкой)\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\n\n\u003c!-- wp:list-item --\u003e\n\u003cli\u003e\u003cstrong\u003eБесплатный расчёт:\u003c/strong\u003e Напишите нам — мы подберём количество досок с учётом \u003cstrong\u003eнахлёста, рисунка, отходов и дизайна\u003c/strong\u003e вашей комнаты.\u003c/li\u003e\n\u003c!-- /wp:list-item --\u003e\u003c/ul\u003e\n\u003c!-- /wp:list --\u003e\n\n\u003c!-- wp:quote --\u003e\n\u003cblockquote class=\"wp-block-quote\"\u003e\u003c!-- wp:paragraph --\u003e\n\u003cp\u003e📌 \u003cem\u003eЗаказывайте по квадратным метрам — не по штукам. Мы считаем, чтобы вы не переплачивали.\u003c/em\u003e\u003c/p\u003e\n\u003c!-- /wp:paragraph --\u003e\u003c/blockquote\u003e\n\u003c!-- /wp:quote --\u003e\n\n\u003c!-- wp:separator --\u003e\n\u003chr class=\"wp-block-separator has-alpha-channel-opacity\"/\u003e\n\u003c!-- /wp:separator --\u003e\n\n\u003c!-- wp:heading {\"level\":4} --\u003e\n\u003ch4 class=\"wp-block-heading\"\u003e💡 \u003cstrong\u003eПочему выбирают нас?\u003c/strong\u003e\u003c/h4\u003e\n\u003c!-- /wp:heading --\u003e\n\n\u003c!-- wp:paragraph --\u003e\n\u003cp\u003e✔️ Только \u003cstrong\u003eкамерной сушки ель сорта АВ\u003c/strong\u003e — без сучков, трещин, сколов\u003cbr\u003e✔️ \u003cstrong\u003eГлубокая шлифовка\u003c/strong\u003e — не просто “отшлифовано”, а \u003cstrong\u003eдо уровня мебели\u003c/strong\u003e\u003cbr\u003e✔️ \u003cstrong\u003eВоск + лак \u003cstrong\u003eSirca\u003c/strong\u003e\u003c/strong\u003e — не «покрасили», а \u003cstrong\u003eоблагородили\u003c/strong\u003e\u003cbr\u003e✔️ \u003cstrong\u003eТемно-бордовый цвет\u003c/strong\u003e — не «красный», а \u003cstrong\u003eтёплый, глубокий, с бордовым отливом\u003c/strong\u003e — как в модных интерьерах Москвы и Стокгольма\u003cbr\u003e✔️ \u003cstrong\u003eНастоящая имитация бруса\u003c/strong\u003e — не «доска с пазами», а \u003cstrong\u003eвоссоздание массива\u003c/strong\u003e\u003c/p\u003e\n\u003c!-- /wp:paragraph --\u003e\n\n\u003c!-- wp:separator --\u003e\n\u003chr class=\"wp-block-separator has-alpha-channel-opacity\"/\u003e\n\u003c!-- /wp:separator --\u003e\n\n\u003c!-- wp:heading {\"level\":3} --\u003e\n\u003ch3 class=\"wp-block-heading\"\u003e\u003cstrong\u003eKrashenayaDoska — мы не продаём доски. Мы создаём интерьеры, в которые хочется возвращаться.\u003c/strong\u003e\u003c/h3\u003e\n\u003c!-- /wp:heading --\u003e\n\n\u003c!-- wp:paragraph --\u003e\n\u003cp\u003e\u003cstrong\u003eНатуральная древесина. Европейская обработка. Готовое решение для вашего уюта.\u003c/strong\u003e\u003c/p\u003e\n\u003c!-- /wp:paragraph --\u003e\n\n\u003c!-- wp:quote --\u003e\n\u003cblockquote class=\"wp-block-quote\"\u003e\u003c!-- wp:paragraph --\u003e\n\u003cp\u003e🌿 \u003cem\u003eТемно-бордовый — это не цвет. Это настроение. Тёплое, глубокое, спокойное. Как уютный плед в зимний вечер.\u003c/em\u003e\u003c/p\u003e\n\u003c!-- /wp:paragraph --\u003e\u003c/blockquote\u003e\n\u003c!-- /wp:quote --\u003e",
